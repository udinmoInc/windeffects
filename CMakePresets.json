{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "win64",
      "displayName": "Windows x64",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/Build/cmake",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "23"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "displayName": "Release",
      "configurePreset": "win64",
      "configuration": "Release"
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "configurePreset": "win64",
      "configuration": "Debug"
    }
  ]
}
